{
  "manifest_version": 3,
  "name": "BridgeSign",
  "version": "0.1.0",
  "description": "Real-time sign language ↔ speech translation for video calls",
  "permissions": [
    "activeTab",
    "storage",
    "offscreen"
  ],
  "host_permissions": [
    "https://meet.google.com/*",
    "ws://localhost:3001/*",
    "ws://192.168.1.6:3001/*",
    "http://localhost:8001/*",
    "http://127.0.0.1:8001/*",
    "http://192.168.1.6:8001/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["virtual-camera.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["meet-caption-scraper.js", "motion-tracker.js", "asl-recognition.js", "sign-player.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["models/*", "libs/*", "assets/*"],
      "matches": ["https://meet.google.com/*"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; connect-src 'self' ws://localhost:3001 ws://192.168.1.6:3001 http://localhost:3001 http://localhost:8001 http://192.168.1.6:8001"
  }
}
